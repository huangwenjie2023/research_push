# Copy to .env and fill only the keys you use. Never commit .env.

# Network proxy. Leave enabled if your VPN listens on port 7890.
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# Optional source keys.
GITHUB_TOKEN=
SEMANTIC_SCHOLAR_API_KEY=
IEEE_API_KEY=
X_BEARER_TOKEN=
GROK_API_KEY=

# Optional OpenAI-compatible LLM providers.
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
DEEPSEEK_API_KEY=

